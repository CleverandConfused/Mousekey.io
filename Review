    // Validate rating
    if (selectedRating === 0) {
        document.getElementById('starError').classList.add('show');
        return;
    }

    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.textContent = 'Sending...';

    const title = document.getElementById('reviewTitle').value.trim();
