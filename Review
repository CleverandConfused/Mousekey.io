<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
// Star rating
const starLabels = ['', 'Terrible', 'Poor', 'Average', 'Good', 'Excellent'];
let selectedRating = 0;
const starRow = document.getElementById('starRow');
const starText = document.getElementById('starText');

for (let i = 1; i <= 5; i++) {
    const btn = document.createElement('button');
    btn.className = 'star-btn';
    btn.setAttribute('aria-label', i + ' star' + (i > 1 ? 's' : ''));
    btn.innerHTML = '<svg viewBox="0 0 24 24" class="empty"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>';
    btn.onclick = function() { setRating(i); };
    btn.onmouseenter = function() { previewRating(i); };
    btn.onmouseleave = function() { previewRating(0); };
    starRow.appendChild(btn);
}

function setRating(n) {
    selectedRating = n;
    updateStars(n);
    starText.textContent = starLabels[n];
    document.getElementById('starError').classList.remove('show');
}

function previewRating(n) {
    if (n > 0) {
        updateStars(n);
        starText.textContent = starLabels[n];
    } else {
        updateStars(selectedRating);
        starText.textContent = selectedRating > 0 ? starLabels[selectedRating] : '';
    }
}

function updateStars(n) {
    const svgs = starRow.querySelectorAll('svg');
    svgs.forEach((svg, idx) => {
        svg.className.baseVal = idx < n ? 'filled' : 'empty';
    });
}

function toggleOtherSource() {
    const sel = document.getElementById('reviewSource');
    const other = document.getElementById('reviewSourceOther');
    if (sel.value === 'Other') {
        other.style.display = 'block';
        other.focus();
    } else {
        other.style.display = 'none';
        other.value = '';
    }
}

