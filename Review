        '',
        'Title: ' + (title || '(none)'),
        '',
        'Review:',
        body || '(no review text)',
        '',
        'Country: ' + (country || '(not specified)'),
        'Device: ' + (device || '(not specified)'),
        'Discovered via: ' + (source || '(not specified)'),
        'Name: ' + (name || 'Anonymous'),
        '',
        '---',
        'Submitted from mousekey review page'
    ].join('\n');

    // Use mailto as the delivery mechanism
    const mailtoLink = 'mailto:MSKey093@gmail.com?subject=' + subject + '&body=' + encodeURIComponent(bodyText.replace(/\\n/g, '\n'));

    // Open mail client
    window.location.href = mailtoLink;

    // Show success after a moment
    setTimeout(function() {
        document.getElementById
